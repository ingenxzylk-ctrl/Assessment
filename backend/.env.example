PORT=5000

# Gemini (scalp analysis)
GEMINI_API_KEY=your_key_from_https://aistudio.google.com/apikey
# GEMINI_API_KEYS=key1,key2
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_RETRIES=2

# --- Assessment report PDF → storage → org email ---
# Local folder for PDFs/JSON (default: backend/storage/reports)
# REPORT_STORAGE_DIR=/absolute/path/to/reports

# Organisation inbox that receives every assessment PDF
ORG_REPORT_EMAIL=reports@zylkhealth.com

# SMTP (required to actually send email; without these the PDF is still saved locally)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Zylk Health Reports <reports@zylkhealth.com>"
# Or use a single connection URL:
# SMTP_URL=smtps://user:pass@smtp.example.com:465

# Optional S3 storage (if unset, reports are stored on local disk)
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET=zylk-assessment-reports
# AWS_S3_PREFIX=assessment-reports
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
