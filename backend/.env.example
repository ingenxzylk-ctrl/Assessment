PORT=5000

# Gemini (scalp analysis)
GEMINI_API_KEY=your_key_from_https://aistudio.google.com/apikey
# GEMINI_API_KEYS=key1,key2
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_RETRIES=2

# --- Assessment report PDF → Google Drive + org email ---
# Local backup folder (always written; default: backend/storage/reports)
# REPORT_STORAGE_DIR=/absolute/path/to/reports

# Organisation inbox that receives every assessment PDF
ORG_REPORT_EMAIL=reports@zylkhealth.com

# SMTP (required to actually send email; without these the PDF is still saved)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Zylk Health Reports <reports@zylkhealth.com>"
# Or use a single connection URL:
# SMTP_URL=smtps://user:pass@smtp.example.com:465

# --- Google Drive (primary cloud storage for PDFs) ---
# 1. Create a Google Cloud project → enable Google Drive API
# 2. Create a Service Account → download JSON key
# 3. Create a Drive folder (e.g. "Zylk Assessment Reports")
# 4. Share that folder with the service account email (Editor access)
# 5. Paste the folder ID from the Drive URL:
#    https://drive.google.com/drive/folders/THIS_IS_THE_FOLDER_ID
GOOGLE_DRIVE_FOLDER_ID=your_shared_folder_id

# Option A — path to the downloaded service-account JSON file:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Option B — inline credentials (useful on cloud hosts):
# GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@project.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Option C — full JSON blob as a single env var:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","client_email":"...","private_key":"..."}

# Optional: make each PDF link publicly viewable (default: false — rely on folder sharing)
# GOOGLE_DRIVE_MAKE_LINK_PUBLIC=false

# Optional S3 storage (used only if Google Drive is not configured)
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET=zylk-assessment-reports
# AWS_S3_PREFIX=assessment-reports
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
