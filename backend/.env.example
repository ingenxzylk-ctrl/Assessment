PORT=5000

# Primary Gemini key (required)
# Create at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here

# Optional comma-separated failover keys used when the primary key hits quota
# GEMINI_API_KEYS=backup_key_1,backup_key_2

# Preferred model (fallbacks are tried automatically)
GEMINI_MODEL=gemini-2.5-flash

# Retries for transient rate limits only (hard quota is never retried)
# GEMINI_RETRIES=2

# When Gemini quota is hit, still complete the quiz using the quiz stage (default: true)
# GEMINI_QUOTA_FALLBACK=true

# Skip calling Google for this many ms after a hard quota hit (default: 60000)
# GEMINI_QUOTA_COOLDOWN_MS=60000
