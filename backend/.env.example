PORT=5000

# Gemini (scalp analysis)
GEMINI_API_KEY=your_key_from_https://aistudio.google.com/apikey
# GEMINI_API_KEYS=key1,key2
GEMINI_MODEL=gemini-2.5-flash

# --- Assessment report PDF → Google Drive + org email ---
ORG_REPORT_EMAIL=reports@zylkhealth.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Zylk Health Reports <reports@zylkhealth.com>"

# Folder that receives PDFs (from Drive URL .../folders/FOLDER_ID)
GOOGLE_DRIVE_FOLDER_ID=your_shared_folder_id

# ============================================================
# Google Drive auth — pick ONE method
# ============================================================

# --- Method A (RECOMMENDED for personal Gmail / My Drive) ---
# Service accounts CANNOT save into personal My Drive (no storage quota).
# Use OAuth with the Google account that owns the folder instead.
#
# 1. Cloud Console → Credentials → Create OAuth client (Desktop or Web)
# 2. Add redirect: http://localhost:3333/oauth2callback
# 3. Put client id/secret below, then run:
#      cd backend && node scripts/get-google-drive-token.js
# 4. Paste the printed GOOGLE_DRIVE_REFRESH_TOKEN here
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
# GOOGLE_DRIVE_REDIRECT_URI=http://localhost:3333/oauth2callback

# --- Method B (Google Workspace Shared Drive + service account) ---
# Personal My Drive will fail with: "Service Accounts do not have storage quota".
# Fix: create a Shared Drive → add service account as Content Manager →
# use a folder ID inside that Shared Drive.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# Or:
# GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@project.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional: make each PDF link publicly viewable
# GOOGLE_DRIVE_MAKE_LINK_PUBLIC=false
